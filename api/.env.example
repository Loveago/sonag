# PostgreSQL (prod). For quick local dev, you can use SQLite by switching provider in schema.prisma to "sqlite" and using: DATABASE_URL="file:./dev.db"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/learnify?schema=public"

PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=learnify-videos
# Leave empty to use local filesystem fallback (uploads/) in dev
S3_ENABLED=false

# Admin seed
SEED_ADMIN_EMAIL=admin@learnify.dev
SEED_ADMIN_PASSWORD=admin123
